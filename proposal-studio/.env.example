# Supabase — URL pública y clave anónima (segura para exponer al cliente).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública del sitio (sin barra final), ej. https://app.proposalstudio.com
# OBLIGATORIA en producción: se usa para construir el link de recuperación de
# contraseña (redirectTo de /update-password). Si falta en producción, el
# servidor falla explícitamente en vez de apuntar a localhost.
# En desarrollo, si se omite, se usa http://localhost:3000 como fallback.
NEXT_PUBLIC_SITE_URL=

# Service Role Key — SOLO uso en servidor (seed scripts, jobs administrativos).
# Nunca prefijar con NEXT_PUBLIC_. Nunca importar desde código de cliente.
SUPABASE_SERVICE_ROLE_KEY=
