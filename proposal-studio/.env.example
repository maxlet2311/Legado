# Supabase — URL pública y clave anónima (segura para exponer al cliente).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública del sitio (sin barra final), ej. https://app.proposalstudio.com
# OBLIGATORIA en producción: se usa para construir el link de recuperación de
# contraseña (redirectTo de /update-password). Si falta en producción, el
# servidor falla explícitamente en vez de apuntar a localhost.
# En desarrollo, si se omite, se usa http://localhost:3000 como fallback.
# En preview deploys de Vercel se usa VERCEL_URL como fallback si falta esta
# variable (VERCEL_URL la provee Vercel automáticamente, no hace falta setearla).
NEXT_PUBLIC_SITE_URL=

# Service Role Key — SOLO uso en servidor (seed scripts, jobs administrativos).
# Nunca prefijar con NEXT_PUBLIC_. Nunca importar desde código de cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago (Etapa 4) — Access Token de "Tus integraciones". Empieza con
# TEST- en credenciales de prueba y APP_USR- en producción. Server-only:
# nunca prefijar con NEXT_PUBLIC_.
MERCADO_PAGO_ACCESS_TOKEN=

# Secreto de validación de webhooks de Mercado Pago (Tus integraciones >
# Webhooks > Configurar notificación). Usado para validar el header
# x-signature en POST /api/webhooks/mercado-pago. Server-only.
MERCADO_PAGO_WEBHOOK_SECRET=

# SOLO desarrollo local: permite aceptar webhooks sin firma válida cuando no
# hay forma de configurar el secreto real contra un túnel local. Se ignora
# siempre que NODE_ENV=production, sin excepción. No setear en ningún entorno
# desplegado.
MERCADO_PAGO_ALLOW_UNSIGNED_WEBHOOKS=false

# Días de período de gracia tras un pago rechazado/en mora antes de que la
# membresía pierda el acceso. Opcional — default 5 si se omite.
MEMBERSHIP_GRACE_PERIOD_DAYS=5

# Modo de transición del guard de membresía (Etapa 5). Valores: off | audit | enforce.
# - off: solo sesión + perfil activo (sin consultar memberships). Emergencia/desarrollo.
# - audit (default si se omite): calcula la decisión real y la registra, pero
#   nunca bloquea. Usar mientras las migraciones de membresía no estén aplicadas
#   remotamente o los usuarios existentes no estén migrados.
# - enforce: aplica el bloqueo real. Server-only: nunca prefijar con NEXT_PUBLIC_.
MEMBERSHIP_ENFORCEMENT_MODE=audit

# Resend (Etapa 5) — entrega real del email de activación de cuenta.
# Server-only: nunca prefijar con NEXT_PUBLIC_.
RESEND_API_KEY=

# Remitente verificado en Resend, ej. "Proposal Studio <activacion@proposalstudio.com>".
EMAIL_FROM=

# Google OAuth (Etapa 5) — Client ID/Secret se configuran en el dashboard de
# Supabase (Authentication > Providers > Google), no acá: Supabase Auth
# gestiona el intercambio OAuth directamente. No hay variables de entorno
# propias del proyecto para esto.
